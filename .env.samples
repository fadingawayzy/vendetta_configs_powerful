# Telegram Bot Token (from @BotFather) / Токен Телеграм бота из @BotFather
BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11

# Пароль для просмотра логов
ADMIN_PASSWORD=secret_password

# GitHub Token
GITHUB_TOKEN=ghp_exampletoken1234567890

# Database URL (Render gives this automatically) / URL БД хостинг автоматически выдаёт их
# Format: postgresql+asyncpg://user:pass@host:port/dbname
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/vless_db

# Manual DB Settings (Optional, if no DATABASE_URL) / Ввод настроек БД вручную
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=vless_db
DB_HOST=localhost
DB_PORT=5432